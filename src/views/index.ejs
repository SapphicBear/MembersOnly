<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head.ejs"), { title: title } %>
</head>
<body>
    <div class="wrapper">
    <header>
        <%- include("./partials/header.ejs", { header: header }); %>
        <% if (locals.user) { %>
            <h2>You are logged in <%= user.username %></h2>
            <a href="/log-out">Log out</a>
            <a href="/new-message">New Message</a>
        <% } else { %>
            <h2>Please log in</h2>
            <a href="/sign-in">Please log in</a>
        <% } %>
    </header>
    <main>
        <%- include("./partials/message.ejs", { messages: messages, user: user }); %>
    </main>
    <footer>
        <%- include("./partials/footer.ejs", { links: links }); %>
    </footer>
    </div>
</body>
</html>