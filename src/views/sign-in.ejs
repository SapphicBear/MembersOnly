<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head", { title: title }); %>
</head>
<body>
    <div class="wrapper sign-in">
        <% if (locals.errors) { %>
            <ul class="error-list">
                <% errors.map((error) => { %>
                    <% if (!error.path) { %>
                        <li><%= error.msg %></li>
                    <% } %>
                <% }); %>
            </ul>
        <% } %>
    <main aria-labelledby="main" class="sign-in">
        <h2 id="main">Sign in</h2>
        <form action="/sign-in" method="post" class="form-sign-in" novalidate>
            <div class="form-row">
                <label for="username"></label>
                <input type="text" name="username" id="username" placeholder="Username..." required>
                <% if (locals.errors) { %>
                    <% errors.map((error) => { %>
                        <% if (error.path == "username") { %>
                        <span class="error"><%= error.msg %></span>
                        <% } %>
                    <% });%>
                    <% } %>
            </div>
            <div class="form-row">
                <label for="password"></label>
                <input type="password" name="password" id="password" placeholder="Password..." required>
                <% if (locals.errors) { %>
                    <% errors.map((error) => { %>
                        <% if (error.path == "password") { %>
                        <span class="error"><%= error.msg %></span>
                        <% } %>
                    <% });%>
                    <% } %>
            </div>
            <div class="form-row">
                <button type="submit" class="button">Sign in</button>         
            </div>
            <div class="form-row">
                <p class="sign-up-redirect">Don't have an account? <a href="/sign-up" class="sign-up-link">Sign up here!</a></p>
            </div>
        </form>
    </main>
    <footer>
        <%- include("./partials/footer.ejs", { links: links }); %>
    </footer>
    </div>
    <script>
        const inputElements = document.querySelectorAll("input");
        const errors = document.querySelectorAll(".error");
        const checkInput = (element) => {
            const error = element.srcElement.nextSibling.nextSibling;
            error.remove();
        }
        inputElements.forEach((input) => {
            input.addEventListener("input", (input) => {
                checkInput(input);
            });
        });
    </script>
</body>
</html>