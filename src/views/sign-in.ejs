<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head", { title: title }); %>
</head>
<body>
    <div class="wrapper">
    <main aria-labelledby="main">
        <h2 id="main">Sign in</h2>
        <% if (locals.errors) { %>
            <ul class="error-list">
                <% errors.map((error) => { %>
                    <% if (!error.path) { %>
                        <li><%= error.msg %></li>
                    <% } %>
                <% }); %>
            </ul>
        <% } %>
        <form action="/sign-in" method="post" class="sign-in">
            <div class="form-row">
                <label for="username"></label>
                <input type="text" name="username" id="username" placeholder="Username...">
                <% if (locals.errors) { %>
                    <% errors.map((error) => { %>
                        <% if (error.path == "username") { %>
                        <span class="error"><%= error.msg %></span>
                        <% } %>
                    <% });%>
                    <% } %>
            </div>
            <div class="form-row">
                <label for="password"></label>
                <input type="password" name="password" id="password" placeholder="Password...">
                <% if (locals.errors) { %>
                    <% errors.map((error) => { %>
                        <% if (error.path == "password") { %>
                        <span class="error"><%= error.msg %></span>
                        <% } %>
                    <% });%>
                    <% } %>
            </div>
            <div class="form-row">
                <button type="submit">Sign in</button>         
            </div>
            <div class="form-row">
                <p>Don't have an account? <a href="/sign-up">Sign up here!</a></p>
            </div>
        </form>
    </main>
    <footer>
        <%- include("./partials/footer.ejs", { links: links }); %>
    </footer>
    </div>
</body>
</html>